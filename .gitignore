# Environment variables (contains API keys and secrets)
.env
.env.local
.env.*.local
*.env

# Generated audio files
output/*.mp3
output/*.wav
output/*.json
temp/

# Logs
logs/

# Node.js
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Python (legacy)
__pycache__/
*.pyc
.venv/
venv/

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Next.js build output
.next/

# Vercel
.vercel

# Capacitor native projects — generated artefacts
# ios/ and android/ directories are committed, but not their build output.
ios/App/Pods/
ios/App/App.xcworkspace/xcuserdata/
ios/App/DerivedData/
ios/.DS_Store
android/.gradle/
android/app/build/
android/build/
android/.DS_Store
.capacitor/

# Credentials and secrets (never commit these)
*.pem
*.key
credentials.json
secrets.json
*_secret*
*_credentials*
